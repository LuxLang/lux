                                                             (by.of by.definition (list (by.= reference_=_1b) in.any))
                                                             (by.if in.any in.any))
                                                        in.any)]
                                       (<| ((!.let [reference_=_this deduction]))
                                           (function (_ this_=_true))
                                           ((!.let [reference_=_that deduction]))
                                           (function (_ that_=_true))
                                           (!.= (all by.and
                                                     (by.of' in.any (list (by.= this_=_true) (by.= that_=_true)))
                                                     (by.= ..reflexivity_of_=))
                                                in.any)))))))

(_.the .public transitivity_of_=
       (equality.axiom_of_transitivity .Bit /.=)
       ..transitivity_of_=')

(_.the .public equality
       (comment "TODO: It should be (equality.system .Bit /.equality) instead."
                (equality.system .Bit /.=))
       (all !.and
            ..reflexivity_of_='
            ..symmetry_of_='
            ..transitivity_of_='))

(_.the .public extraction_of_commonality
       (?.let [premise conclusion]
              [test Bit
               then premise
               else premise
               after (-> premise conclusion)]
              (?.= (.if test
                        (after then)
                        (after else))
                   (after (.if test
                               then
                               else))))
       (let [proof (is (-> ?.Proposition ?.Proposition
                           induction.Case)
                       (function (_ @constant if_constant)
                                 (function (_ =_test)
                                           (let [=_test (by.and (by.= =_test) (by.= @constant))
                                                 if' (by.and (in.if =_test in.any in.any)
                                                             (by.= if_constant))]
                                                (!.= if'
                                                     (by.application in.any if'))))))]
            (induction.bit (proof @false ..if_false)
                           (proof @true ..if_true))))

(_.the .public if_identical
       (?.let [any]
              [test Bit
               then_or_else any]
              (?.= (.if test
                        then_or_else
                        then_or_else)
                   then_or_else))
       (let [proof (is (-> ?.Proposition ?.Proposition
                           induction.Case)
                       (function (_ @constant if_constant)
                                 (function (_ =_test)
                                           (let [=_test (by.and (by.= =_test) (by.= @constant))
                                                 if' (by.and (in.if =_test in.any in.any)
                                                             (by.= if_constant))]
                                                (!.= if'
                                                     in.any)))))]
            (induction.bit (proof @false ..if_false)
                           (proof @true ..if_true))))

(_.the .public if_and/or
       (?.let [cause Bit
               effect Bit]
              (?.if (?.= (/.if cause effect)
                         .true)
                    (?.or (?.= cause
                               .false)
                          (?.= effect
                               .true))))
       (<| !.if (function (_ cause_|-_effect))
           (!.or (function (_ |cause_=_false| |effect_=_true|)
                           ((!.let [cause_|-_effect
                                    (!.=' (by.of by.definition (list in.any in.any))
                                          in.any)])
                            (function (_ cause_|-_effect)
                                      (inference.if cause_|-_effect
                                                    (function (_ cause_=_1b effect_=_true)
                                                              (|effect_=_true|
                                                               (!.= (by.= effect_=_true)
                                                                    in.any)))
                                                    (function (_ cause_=_0b true_=_true)
                                                              (|cause_=_false|
                                                               (!.= (all by.and
                                                                         (by.= cause_=_0b)
                                                                         (by.= ..@false))
                                                                    in.any))))))))))

(comment "https://en.wikipedia.org/wiki/Law_of_excluded_middle"
         (_.the .public bit
                (?.let [it Bit]
                       (?.or (?.= it
                                  .false)
                             (?.= it
                                  .true)))
                !.axiom))

(_.the .public anti_reflexivity_of_<
       (total.axiom_of_anti_reflexivity Bit /.<)
       (!.= (all by.and
                 (by.of by.definition (list in.any in.any))
                 (by.= ..complementation_of_and))
            in.any))

(_.the .public only_order
       (?.let [this Bit
               that Bit]
              (?.if (?.= (/.< this that)
                         .true)
                    (?.and (?.= this .true)
                           (?.= that .false))))
       (<| !.if (function (_ <*this&that))
           (<| ((!.let [<*this&that
                        (all by.and
                             (!.=' (by.of by.definition (list in.any in.any))
                                   in.any)
                             (contradiction.then (!.=' in.any by_true)))]))
               (function (_ [this_=_1b not<that>_=_true]))
               ((!.let [not<that>_=_true
                        (all by.and
                             (inference.by 'not)
                             (!.=' (by.= ..double_negation)
                                   (all by.and
                                        (by.= ..false)
                                        by.definition)))]))
               (function (_ that_=_0b))
               (!.and (!.= (by.= this_=_1b)
                           by_true)
                      (!.= (by.= that_=_0b)
                           by.definition)))))

(_.the .public minimum
       (?.let [it Bit]
              (?.= (/.< .false it)
                   .false))
       (!.= (all by.and
                 (by.of by.definition (list in.any in.any))
                 (by.= ..annihilation_of_and))
            in.any))

(_.the .public asymmetry_of_<
       (total.axiom_of_asymmetry Bit /.<)
       (<| !.if (function (_ <*this&that))
           ((!.let_pair (by.by ..only_order (list <*this&that)))
            (function (_ [this_=_true that_=_false])
                      (!.= (all by.and
                                (by.of' in.any (list (by.= that_=_false) (by.= this_=_true)))
                                (by.= ..minimum))
                           in.any)))))

(_.the .public not_equal
       (?.let [this Bit
               that Bit]
              (?.if (?.= (/.= this that)
                         .false)
                    (?.or (?.and (?.= this .false)
                                 (?.= that .true))
                          (?.and (?.= this .true)
                                 (?.= that .false)))))
       (<| !.if (function (_ this_!=_that))
           (!.or (function (_ case_01 case_10)
                           ((!.let [this_!=_that
                                    (!.=' (by.of by.definition (list in.any in.any))
                                          in.any)])
                            (function (_ this_!=_that)
                                      (inference.if this_!=_that
                                                    (function (_ this_=_1b that_=_false)
                                                              (case_10
                                                               (!.and (!.= (all by.and
                                                                                (by.= this_=_1b)
                                                                                (by.= ..@true))
                                                                           in.any)
                                                                      (!.= (by.= that_=_false)
                                                                           in.any))))
                                                    (function (_ this_=_0b not<that>_=_false)
                                                              (<| ((!.let [not<that>_=_false
                                                                           (all by.and
                                                                                (inference.by 'not)
                                                                                (!.=' (by.= ..double_negation)
                                                                                      (by.= ..true)))]))
                                                                  (function (_ that_=_true))
                                                                  (case_01
                                                                   (!.and (!.= (all by.and
                                                                                    (by.= this_=_0b)
                                                                                    (by.= ..@false))
                                                                               in.any)
                                                                          (!.= (by.= that_=_true)
                                                                               in.any))))))))))))

(_.the .public totality_of_<
       (total.axiom_of_totality Bit /.= /.<)
       (<| !.if (function (_ equality))
           !.if (function (_ this_!=_that))
           (!.or (function (_ |that_<_this| |this_<_that|)
                           (induction.or (by.by ..not_equal (list this_!=_that))
                                         (function (_ this_=_false_&&_that_=_true)
                                                   ((!.let_pair {try.:Success this_=_false_&&_that_=_true})
                                                    (function (_ [this_=_false that_=_true])
                                                              (|this_<_that|
                                                               (!.= (all by.and
                                                                         (by.of by.definition (list (by.= that_=_true) (by.= this_=_false)))
                                                                         (by.if (by.= (?.in_reverse @true))
                                                                                (by.= ..true)))
                                                                    in.any)))))
                                         (function (_ this_=_true_&&_that_=_false)
                                                   ((!.let_pair {try.:Success this_=_true_&&_that_=_false})
                                                    (function (_ [this_=_true that_=_false])
                                                              (|that_<_this|
                                                               (!.= (all by.and
                                                                         (by.of by.definition (list (by.= this_=_true) (by.= that_=_false)))
                                                                         (by.if (by.= (?.in_reverse @true))
                                                                                (by.= ..true)))
                                                                    in.any))))))))))

(_.the .public disjunction
       (monoid.system .Bit .false .and/or)
       (all !.and
            (!.= (by.= ..identity_of_and/or)
                 in.any)
            (!.= (all by.and
                      (by.= ..commutativity_of_and/or)
                      (by.= ..identity_of_and/or))
                 in.any)
            (!.= (by.= (?.in_reverse ..associativity_of_and/or))
                 in.any)
            ))

(_.the .public exclusive_disjunction
       (monoid.system .Bit .false /.or)
       (all !.and
            (!.= (by.= ..identity_of_or)
                 in.any)
            (!.= (all by.and
                      (by.= ..commutativity_of_or)
                      (by.= ..identity_of_or))
                 in.any)
            (!.= (by.= (?.in_reverse ..associativity_of_or))
                 in.any)
            ))

(_.the .public conjunction
       (monoid.system .Bit .true .and)
       (all !.and
            (!.= (by.= ..identity_of_and)
                 in.any)
            (!.= (all by.and
                      (by.= ..commutativity_of_and)
                      (by.= ..identity_of_and))
                 in.any)
            (!.= (by.= (?.in_reverse ..associativity_of_and))
                 in.any)
            ))
