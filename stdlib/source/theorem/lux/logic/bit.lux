(.using
 [library
  [lux (.except and and/or if not false true)
   ["_" theorem (.only)
    ["?" proposition]
    ["!" proof (.only)
     ["[0]" induction]
     ["[0]" inference]
     ["[0]" contradiction]]
    ["in" substitution]
    ["by" rule]]
   [error
    ["[0]" try]]
   [abstract
    ["[0]" monad]
    ["[0]" equality
     ["[1]" \\theorem]]
    [order
     ["[0]" total
      ["[1]" strong
       ["[1]" \\theorem]]]]
    ["[0]" monoid
     ["[1]" \\theorem]]]
   [meta
    ["[0]" provenance]]
   [compiler
    [language
     [lux
      ["[0]" analysis]]]]
   ["[0]" function]
   [macro
    ["[0]" template]]]]
 [\\library
  ["[0]" /]])

(the .public (and/or this that)
     (-> in.Rule in.Rule
         in.Rule)
     (in.if this in.any that))

(the .public (and this that)
     (-> in.Rule in.Rule
         in.Rule)
     (in.if this that in.any))

(the (if cause effect)
     (-> in.Rule in.Rule
         in.Rule)
     (by.application (by.application in.any cause) effect))

(the (not it)
     (-> in.Rule
         in.Rule)
     (by.application in.any it))

(comment "https://en.wikipedia.org/wiki/Boolean_algebra#Laws"
         (the (|not| it)
              (Change in.Rule)
              (all by.and
                   (by.application by.definition it)
                   by.reification
                   (by.if in.any in.any))))

(the by_true
     (all by.and
          by.definition
          (|not| by.definition)))

(comment "Lemma"
         (these (_.the @false
                       (?.= 0b
                            .false)
                       (!.= in.any
                            by.definition))

                (_.the @true
                       (?.= 1b
                            .true)
                       (!.= in.any
                            by_true))))

(the (of/1 abstraction argument)
     (-> in.Rule in.Rule
         in.Rule)
     (all by.and
          (by.application abstraction argument)
          by.reification))

(_.the .public if_true
       (?.let [it]
              [then it
               else it]
              (?.= (.if .true
                        then
                        else)
                   then))
       (!.= (by.if by_true in.any)
            in.any))

(_.the .public if_false
       (?.let [it]
              [then it
               else it]
              (?.= (.if .false
                        then
                        else)
                   else))
       (!.= (by.if by.definition in.any)
            in.any))

(_.the .public true
       (?.= (.not .false)
            .true)
       (!.= in.any
            by.definition))

(comment "https://en.wikipedia.org/wiki/Double_negation"
         (_.the .public double_negation
                (?.let [it Bit]
                       (?.= (.not (.not it))
                            it))
                (let [$= (function (_ ==)
                                   (!.= (|not| (|not| (by.= ==)))
                                        (by.= ==)))]
                     (induction.bit (function (_ =_false)
                                              ($= =_false))
                                    (function (_ =_true)
                                              ($= =_true))))))

(_.the .public false
       (?.= (.not .true)
            .false)
       (!.= (all by.and
                 (by.application in.any by.definition)
                 (by.= double_negation))
            in.any))

(comment "https://en.wikipedia.org/wiki/Idempotence"
         (template.with [,theorem ,composition ,if_false ,if_true]
                        [(_.the .public ,theorem
                                (?.let [it Bit]
                                       (?.= (,composition it it)
                                            it))
                                (induction.bit (function (_ ==)
                                                         (!.= (by.if (by.= ==) ,if_false)
                                                              (by.= ==)))
                                               (function (_ ==)
                                                         (!.= (by.if (by.= ==) ,if_true)
                                                              (by.= ==)))))]

                        [[idempotence_of_and/or .and/or (by.= ==) in.any]
                         [idempotence_of_and .and in.any (by.= ==)]]))

(template.with [,theorem ,composition ,identity ,value]
               [(_.the .public ,theorem
                       (?.let [it Bit]
                              (?.= (,composition ,identity it)
                                   it))
                       (!.= (by.if ,value in.any)
                            in.any))]

               [[identity_of_and/or .and/or .false by.definition]
                [identity_of_and .and .true by_true]])

(template.with [,theorem ,composition ,identity ,value]
               [(_.the .public ,theorem
                       (?.let [it Bit]
                              (?.= (,composition ,identity it)
                                   ,identity))
                       (!.= (by.if ,value in.any)
                            ,value))]

               [[annihilation_of_and/or .and/or .true by_true]
                [annihilation_of_and .and .false by.definition]])

(comment "https://en.wikipedia.org/wiki/Commutative_property"
         (_.the .public commutativity_of_and/or
                (?.let [this Bit
                        that Bit]
                       (?.= (.and/or this that)
                            (.and/or that this)))
                (induction.bit (function (_ this_=_false)
                                         (let [this_=_false (by.and (by.= this_=_false) (by.= @false))]
                                              (induction.bit (function (_ that_=_false)
                                                                       (let [that_=_false (by.and (by.= that_=_false) (by.= @false))]
                                                                            (!.= (all by.and
                                                                                      (in.if this_=_false in.any in.any)
                                                                                      (by.= ..identity_of_and/or)
                                                                                      that_=_false)
                                                                                 (all by.and
                                                                                      (in.if this_=_false in.any in.any)
                                                                                      (by.= ..identity_of_and/or)
                                                                                      this_=_false))))
                                                             (function (_ that_=_true)
                                                                       (let [that_=_true (by.and (by.= that_=_true) (by.= @true))]
                                                                            (!.= (all by.and
                                                                                      (in.if this_=_false in.any in.any)
                                                                                      (by.= ..identity_of_and/or)
                                                                                      that_=_true)
                                                                                 (all by.and
                                                                                      (in.if that_=_true in.any in.any)
                                                                                      (by.= ..annihilation_of_and/or))))))))
                               (function (_ this_=_true)
                                         (let [this_=_true (by.and (by.= this_=_true) (by.= @true))]
                                              (induction.bit (function (_ that_=_false)
                                                                       (let [that_=_false (by.and (by.= that_=_false) (by.= @false))]
                                                                            (!.= (all by.and
                                                                                      (in.if this_=_true in.any in.any)
                                                                                      (by.= ..annihilation_of_and/or))
                                                                                 (all by.and
                                                                                      (in.if that_=_false in.any in.any)
                                                                                      (by.= ..identity_of_and/or)
                                                                                      this_=_true))))
                                                             (function (_ that_=_true)
                                                                       (let [that_=_true (by.and (by.= that_=_true) (by.= @true))]
                                                                            (!.= (all by.and
                                                                                      (in.if this_=_true in.any in.any)
                                                                                      (by.= ..annihilation_of_and/or))
                                                                                 (all by.and
                                                                                      (in.if that_=_true in.any in.any)
                                                                                      (by.= ..annihilation_of_and/or)))))))))))

(_.the .public commutativity_of_and
       (?.let [this Bit
               that Bit]
              (?.= (.and this that)
                   (.and that this)))
       (induction.bit (function (_ =this)
                                (let [=this (by.and (by.= =this) (by.= @false))]
                                     (induction.bit (function (_ =that)
                                                              (let [=that (by.and (by.= =that) (by.= @false))]
                                                                   (!.= (all by.and
                                                                             (in.if =this in.any in.any)
                                                                             (by.= ..annihilation_of_and))
                                                                        (all by.and
                                                                             (in.if =that in.any in.any)
                                                                             (by.= ..annihilation_of_and)))))
                                                    (function (_ =that)
                                                              (let [=that (by.and (by.= =that) (by.= @true))]
                                                                   (!.= (all by.and
                                                                             (in.if =this in.any in.any)
                                                                             (by.= ..annihilation_of_and))
                                                                        (all by.and
                                                                             (in.if =that in.any in.any)
                                                                             (by.= ..identity_of_and)
                                                                             =this)))))))
                      (function (_ =this)
                                (let [=this (by.and (by.= =this) (by.= @true))]
                                     (induction.bit (function (_ =that)
                                                              (let [=that (by.and (by.= =that) (by.= @false))]
                                                                   (!.= (all by.and
                                                                             (in.if =this in.any in.any)
                                                                             (by.= ..identity_of_and)
                                                                             =that)
                                                                        (all by.and
                                                                             (in.if =that in.any in.any)
                                                                             (by.= ..annihilation_of_and)))))
                                                    (function (_ =that)
                                                              (let [=that (by.and (by.= =that) (by.= @true))]
                                                                   (!.= (all by.and
                                                                             (in.if =this in.any in.any)
                                                                             (by.= ..identity_of_and)
                                                                             =that)
                                                                        (all by.and
                                                                             (in.if =that in.any in.any)
                                                                             (by.= ..identity_of_and)
                                                                             =this)))))))))

(comment "https://en.wikipedia.org/wiki/Complement_(set_theory)"
         "https://en.wikipedia.org/wiki/Law_of_excluded_middle"
         (_.the .public complementation_of_and/or
                (?.let [it Bit]
                       (?.= (.and/or it (.not it))
                            .true))
                (induction.bit (function (_ =_false)
                                         (let [=_false (by.and (by.= =_false) (by.= @false))]
                                              (!.= (all by.and
                                                        (in.if =_false in.any in.any)
                                                        (by.= identity_of_and/or)
                                                        (by.application in.any =_false))
                                                   by.definition)))
                               (function (_ =_true)
                                         (let [=_true (by.and (by.= =_true) (by.= @true))]
                                              (!.= (all by.and
                                                        (in.if =_true in.any in.any)
                                                        (by.= annihilation_of_and/or))
                                                   in.any))))))

(comment "https://en.wikipedia.org/wiki/Law_of_noncontradiction"
         (_.the .public complementation_of_and
                (?.let [it Bit]
                       (?.= (.and it (.not it))
                            .false))
                (induction.bit (function (_ =it)
                                         (let [=it (by.and (by.= =it) (by.= @false))]
                                              (!.= (all by.and
                                                        (in.if =it in.any in.any)
                                                        (by.= annihilation_of_and))
                                                   in.any)))
                               (function (_ =it)
                                         (let [=it (by.and (by.= =it) (by.= @true))]
                                              (!.= (all by.and
                                                        (in.if =it in.any in.any)
                                                        (by.= identity_of_and)
                                                        (by.application in.any =it)
                                                        (by.= ..false))
                                                   in.any))))))

(comment "https://en.wikipedia.org/wiki/Associative_property"
         (_.the .public associativity_of_and/or
                (?.let [$0 Bit
                        $1 Bit
                        $2 Bit]
                       (?.= (.and/or $0 (.and/or $1 $2))
                            (.and/or (.and/or $0 $1) $2)))
                (induction.bit (function (_ $0_=_false)
                                         (let [$0_=_false (by.and (by.= $0_=_false) (by.= @false))]
                                              (induction.bit (function (_ $1_=_false)
                                                                       (let [$1_=_false (by.and (by.= $1_=_false) (by.= @false))]
                                                                            (!.= (all by.and
                                                                                      (in.if $0_=_false in.any in.any)
                                                                                      (by.= identity_of_and/or)
                                                                                      (in.if $1_=_false in.any in.any)
                                                                                      (by.= identity_of_and/or))
                                                                                 (all by.and
                                                                                      (in.if (all by.and
                                                                                                  (in.if $0_=_false in.any in.any)
                                                                                                  (by.= identity_of_and/or)
                                                                                                  $1_=_false)
                                                                                             in.any in.any)
                                                                                      (by.= identity_of_and/or)))))
                                                             (function (_ $1_=_true)
                                                                       (let [$1_=_true (by.and (by.= $1_=_true) (by.= @true))]
                                                                            (!.= (all by.and
                                                                                      (in.if $0_=_false in.any in.any)
                                                                                      (by.= identity_of_and/or)
                                                                                      (in.if $1_=_true in.any in.any)
                                                                                      (by.= annihilation_of_and/or))
                                                                                 (all by.and
                                                                                      (in.if (all by.and
                                                                                                  (in.if $0_=_false in.any in.any)
                                                                                                  (by.= identity_of_and/or)
                                                                                                  $1_=_true)
                                                                                             in.any in.any)
                                                                                      (by.= annihilation_of_and/or))))))))
                               (function (_ $0_=_true)
                                         (let [$0_=_true (by.and (by.= $0_=_true) (by.= @true))]
                                              (!.= (all by.and
                                                        (in.if $0_=_true in.any in.any)
                                                        (by.= annihilation_of_and/or))
                                                   (all by.and
                                                        (in.if (all by.and
                                                                    (in.if $0_=_true in.any in.any)
                                                                    (by.= annihilation_of_and/or))
                                                               in.any in.any)
                                                        (by.= annihilation_of_and/or))))))))

(_.the .public associativity_of_and
       (?.let [$0 Bit
               $1 Bit
               $2 Bit]
              (?.= (.and $0 (.and $1 $2))
                   (.and (.and $0 $1) $2)))
       (induction.bit (function (_ =0)
                                (let [=0 (by.and (by.= =0) (by.= @false))]
                                     (!.= (all by.and
                                               (in.if =0 in.any in.any)
                                               (by.= annihilation_of_and))
                                          (all by.and
                                               (in.if (all by.and
                                                           (in.if =0 in.any in.any)
                                                           (by.= annihilation_of_and))
                                                      in.any in.any)
                                               (by.= annihilation_of_and)))))
                      (function (_ =0)
                                (let [=0 (by.and (by.= =0) (by.= @true))]
                                     (induction.bit (function (_ =1)
                                                              (let [=1 (by.and (by.= =1) (by.= @false))]
                                                                   (!.= (all by.and
                                                                             (in.if =0 in.any in.any)
                                                                             (by.= identity_of_and)
                                                                             (in.if =1 in.any in.any)
                                                                             (by.= annihilation_of_and))
                                                                        (all by.and
                                                                             (in.if (all by.and
                                                                                         (in.if =0 in.any in.any)
                                                                                         (by.= identity_of_and)
                                                                                         =1)
                                                                                    in.any in.any)
                                                                             (by.= annihilation_of_and)))))
                                                    (function (_ =1)
                                                              (let [=1 (by.and (by.= =1) (by.= @true))]
                                                                   (!.= (all by.and
                                                                             (in.if =0 in.any in.any)
                                                                             (by.= identity_of_and)
                                                                             (in.if =1 in.any in.any)
                                                                             (by.= identity_of_and))
                                                                        (all by.and
                                                                             (in.if (all by.and
                                                                                         (in.if =0 in.any in.any)
                                                                                         (by.= identity_of_and)
                                                                                         =1)
                                                                                    in.any in.any)
                                                                             (by.= identity_of_and))))))))))

(comment "https://en.wikipedia.org/wiki/Distributive_property"
         (_.the .public distributivity_of_and/or
                (?.let [$0 Bit
                        $1 Bit
                        $2 Bit]
                       (?.= (.and (.and/or $0 $1) (.and/or $0 $2))
                            (.and/or $0 (.and $1 $2))))
                (induction.bit (function (_ =_false)
                                         (let [=_false (by.and (by.= =_false) (by.= @false))
                                               $or_false (all by.and
                                                              (in.if =_false in.any in.any)
                                                              (by.= identity_of_and/or))]
                                              (!.= (in.if $or_false $or_false in.any)
                                                   $or_false)))
                               (function (_ =_true)
                                         (let [=_true (by.and (by.= =_true) (by.= @true))
                                               $or_true (all by.and
                                                             (in.if =_true in.any in.any)
                                                             (by.= annihilation_of_and/or))]
                                              (!.= (all by.and
                                                        (in.if $or_true $or_true in.any)
                                                        (by.= identity_of_and))
                                                   $or_true))
                                         ))))

(_.the .public distributivity_of_and
       (?.let [$0 Bit
               $1 Bit
               $2 Bit]
              (?.= (.and/or (.and $0 $1) (.and $0 $2))
                   (.and $0 (.and/or $1 $2))))
       (induction.bit (function (_ =0)
                                (let [=0 (by.and (by.= =0) (by.= @false))
                                      annihilation (all by.and
                                                        (in.if =0 in.any in.any)
                                                        (by.= annihilation_of_and))]
                                     (!.= (all by.and
                                               (in.if annihilation in.any annihilation)
                                               (by.= identity_of_and/or))
                                          annihilation)))
                      (function (_ =0)
                                (let [=0 (by.and (by.= =0) (by.= @true))
                                      identity (all by.and
                                                    (in.if =0 in.any in.any)
                                                    (by.= identity_of_and))]
                                     (!.= (in.if identity in.any identity)
                                          identity))
                                )))

(comment "https://en.wikipedia.org/wiki/De_Morgan%27s_laws"
         (_.the .public negation_of_and/or
                (?.let [this Bit
                        that Bit]
                       (?.= (.and (.not this) (.not that))
                            (.not (.and/or this that))))
                (induction.bit (function (_ =this)
                                         (let [=this (by.and (by.= =this) (by.= @false))]
                                              (!.= (all by.and
                                                        (in.if (all by.and
                                                                    (by.application in.any =this)
                                                                    (by.= ..true))
                                                               in.any in.any)
                                                        (by.= identity_of_and))
                                                   (by.application in.any
                                                                   (all by.and
                                                                        (in.if =this in.any in.any)
                                                                        (by.= identity_of_and/or))))))
                               (function (_ =this)
                                         (let [=this (by.and (by.= =this) (by.= @true))]
                                              (!.= (all by.and
                                                        (in.if (all by.and
                                                                    (by.application in.any =this)
                                                                    (by.= ..false))
                                                               in.any in.any)
                                                        (by.= annihilation_of_and))
                                                   (all by.and
                                                        (by.application in.any
                                                                        (all by.and
                                                                             (in.if =this in.any in.any)
                                                                             (by.= annihilation_of_and/or)))
                                                        (by.= ..false))))))))

(_.the .public negation_of_and
       (?.let [this Bit
               that Bit]
              (?.= (.and/or (.not this) (.not that))
                   (.not (.and this that))))
       (induction.bit (function (_ =this)
                                (let [=this (by.and (by.= =this) (by.= @false))]
                                     (!.= (all by.and
                                               (in.if (all by.and
                                                           (by.application in.any =this)
                                                           (by.= ..true))
                                                      in.any in.any)
                                               (by.= annihilation_of_and/or))
                                          (all by.and
                                               (by.application in.any
                                                               (all by.and
                                                                    (in.if =this in.any in.any)
                                                                    (by.= annihilation_of_and)))
                                               (by.= ..true)))))
                      (function (_ =this)
                                (let [=this (by.and (by.= =this) (by.= @true))]
                                     (!.= (all by.and
                                               (in.if (all by.and
                                                           (by.application in.any =this)
                                                           (by.= ..false))
                                                      in.any in.any)
                                               (by.= identity_of_and/or))
                                          (by.application in.any
                                                          (all by.and
                                                               (in.if =this in.any in.any)
                                                               (by.= identity_of_and))))))))

(_.the .public absorption_of_and/or
       (?.let [this Bit
               that Bit]
              (?.= (.and/or this (.and this that))
                   this))
       (induction.bit (function (_ =this)
                                (let [=this (by.and (by.= =this) (by.= @false))]
                                     (!.= (all by.and
                                               (in.if =this in.any in.any)
                                               (by.= identity_of_and/or)
                                               (in.if =this in.any in.any)
                                               (by.= annihilation_of_and))
                                          =this)))
                      (function (_ =this)
                                (let [=this (by.and (by.= =this) (by.= @true))]
                                     (!.= (all by.and
                                               (in.if =this in.any in.any)
                                               (by.= annihilation_of_and/or))
                                          =this)))))

(_.the .public absorption_of_and
       (?.let [this Bit
               that Bit]
              (?.= (.and this (.and/or this that))
                   this))
       (induction.bit (function (_ =this)
                                (let [=this (by.and (by.= =this) (by.= @false))]
                                     (!.= (all by.and
                                               (in.if =this in.any in.any)
                                               (by.= annihilation_of_and))
                                          =this)))
                      (function (_ =this)
                                (let [=this (by.and (by.= =this) (by.= @true))]
                                     (!.= (all by.and
                                               (in.if =this in.any in.any)
                                               (by.= identity_of_and)
                                               (in.if =this in.any in.any)
                                               (by.= annihilation_of_and/or))
                                          =this)))))

(_.the .public if_not
       (?.let [it]
              [test Bit
               then it
               else it]
              (?.= (.if (.not test)
                        then
                        else)
                   (.if test
                        else
                        then)))
       (induction.bit (function (_ =this)
                                (let [=this (by.and (by.= =this) (by.= @false))]
                                     (!.= (all by.and
                                               (in.if (all by.and
                                                           (by.application in.any =this)
                                                           (by.= ..true))
                                                      in.any in.any)
                                               (by.= if_true))
                                          (all by.and
                                               (in.if =this in.any in.any)
                                               (by.= if_false)))))
                      (function (_ =this)
                                (let [=this (by.and (by.= =this) (by.= @true))]
                                     (!.= (all by.and
                                               (in.if (all by.and
                                                           (by.application in.any =this)
                                                           (by.= ..false))
                                                      in.any in.any)
                                               (by.= if_false))
                                          (all by.and
                                               (in.if =this in.any in.any)
                                               (by.= if_true)))))))

(comment "https://en.wikipedia.org/wiki/Exclusive_or#Properties"
         (_.the .public identity_of_or
                (?.let [it Bit]
                       (?.= (/.or .false it)
                            it))
                (!.= (all by.and
                          (of/1 (of/1 by.definition by.definition) in.any)
                          (by.if in.any in.any))
                     in.any)))

(_.the .public negation_by_or
       (?.let [it Bit]
              (?.= (/.or .true it)
                   (.not it)))
       (!.= (all by.and
                 (of/1 (of/1 by.definition by_true) in.any)
                 (by.if in.any in.any))
            in.any))

(_.the .public non_idempotence_of_or
       (?.let [it Bit]
              (?.= (/.or it it)
                   .false))
       (induction.bit (function (_ =it)
                                (!.= (all by.and
                                          (of/1 (of/1 by.definition (by.= =it)) (by.= =it))
                                          (by.if in.any in.any))
                                     by.definition))
                      (function (_ =it')
                                (let [=it (by.and (by.= =it') (by.= @true))]
                                     (!.= (all by.and
                                               (of/1 (of/1 by.definition (by.= =it')) =it)
                                               (by.if in.any in.any)
                                               (by.= ..false))
                                          in.any)))))

(comment "https://en.wikipedia.org/wiki/Complement_(set_theory)"
         (_.the .public complementation_of_or
                (?.let [it Bit]
                       (?.= (/.or it (.not it))
                            .true))
                (induction.bit (function (_ =it')
                                         (let [=it (by.and (by.= =it') (by.= @false))]
                                              (!.= (all by.and
