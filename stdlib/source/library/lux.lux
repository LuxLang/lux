(comment (every (Monad m)
                (Interface
                 (is (for_any (_ a)
                              (-> a
                                  (m a)))
                     :pure)
                 (is (for_any (_ a b)
                              (-> (-> a (m b))
                                  (-> (m a) (m b))))
                     :then)))
         (the' .private Monad
