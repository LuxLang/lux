             (function' (_ export_policy name type value)
                        (code:form (list ('prelude "the#") export_policy name ('is# type value))))))

(.the# .private the'
       (.as# (Function Macro' Macro)
             (function' (_ tokens)
                        (.when# tokens
                                (.list# export_policy
                                        {:Form _ name,arguments}
                                        type
                                        body)
