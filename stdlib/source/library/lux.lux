       ..Real)

(the .public variant
     (macro (_ it)
            (meta:pure (list (` {(,* it)})))))

(alias [|]
       ..variant)

(the .public tuple
     (macro (_ it)
            (meta:pure (list (when (list:as_stack (list:in_reverse it))
                                   (stack)
                                   (` [])
                                   
                                   (stack singleton)
                                   singleton
                                   
                                   {:Top right every_left}
                                   (stack:mix (function (_ left right)
                                                        (` (.pair# (, left) (, right))))
                                              right
                                              every_left))))))

