(comment "https://en.wikipedia.org/wiki/Operator_associativity"
         (the' .public left_associative
               Macro
               (macro (_ tokens)
                      (.when# (.list_size# tokens)
                              0 (failure "")
                              1 (failure "")
                              2 (meta:pure (list (.list_item# 2 tokens)))
                              _ (.when# [(.list_item# 0 tokens) (.list_item# 1 tokens)]
                                        [op first]
                                        (meta:pure (list (list:mix (function:flipped (right_associativity op))
                                                                   (list:after 2 tokens)
                                                                   first))))))))

