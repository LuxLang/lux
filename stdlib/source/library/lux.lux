                               (.if# (.int_<# (.as# (Function Natural Integer) limit)
                                              (.as# (Function Natural Integer) item))
                                     (list:mix' (.i64_+# 1 item)
                                                mix
                                                partial
                                                (mix item
                                                     (.list_item# item partial)
                                                     complete))
                                     complete)))
              0 mix partial complete)))

