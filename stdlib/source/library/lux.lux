(alias [Rev]
       ..Revolution)

(the .public match?
     (macro (_ tokens)
            (when (?:value tokens
                           (?:and ?:any
                                  ?:any))
                  {:Some [pattern term]}
                  (monad:let meta:monad
                             ['else (generated_name "'else")]
                             (pure (list (` (..when (, term)
                                                    (, pattern)
                                                    ..true

                                                    (, 'else)
                                                    ..false)))))
                  
                  {:None}
                  (failure ""))))

(every .public (Can ability)
       (for_some (_ entity)
                 [entity
                  (ability entity)]))

(the .public (can ability entity)
     (for_any (_ ability it)
              (-> (ability it) it
                  (Can ability it)))
     [entity ability])

(the .public (ability [entity ability])
     (for_any (_ ability it)
              (-> (Can ability it)
                  (ability it)))
     ability)

(the .public (entity [entity ability])
     (for_any (_ ability it)
              (-> (Can ability it)
                  it))
