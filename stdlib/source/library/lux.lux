                                                                        (.when# (stack:mix (function' (_ parameter offset,body')
                                                                                                      (.when# offset,body'
                                                                                                              [offset body']
                                                                                                              [(.i64_+# 1 offset)
                                                                                                               ('let parameter (quantified_argument offset)
                                                                                                                     (code:universal_quantification body'))]))
                                                                                           [0 (with_quantification (stack:size args)
                                                                                                                   body)]
                                                                                           args)
                                                                                [_ raw]
                                                                                raw))))
                                                     (.if# (initialized_quantification? lux)
                                                           raw
                                                           (..quantified raw))))]}

                             else
                             {:Left ""})
                     
                     _
                     {:Left ""})))

