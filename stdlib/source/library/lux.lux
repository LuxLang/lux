                                                    (-> ($ ! a) ($ ! b))))))}))

(the' .private every_slot_of_monad
      {:Reification Name List}
      (.list# [..prelude ":pure"]
              [..prelude ":then"]))
(the' .private :pure Slot (slot [{:Some [0 0b ..every_slot_of_monad]} Monad]))
(the' .private :then Slot (slot [{:Some [0 1b ..every_slot_of_monad]} Monad]))

