(.comment "https://en.wikipedia.org/wiki/Many-valued_logic"
          (.using
           [library
            [lux (.except false true and not)
             [abstract
              [monoid (.only Monoid)]]
             [math
              [number
               [/64
                ["/" revolution (.open interval)]]]]
             [macro
              ["[0]" template]]]]))

(the .public false Revolution /:minimum)
(the .public true  Revolution /:maximum)

(template.with [<name> <chooser> <monoid> <identity>]
               [(the .public <name>
                     (-> Revolution Revolution Revolution)
                     <chooser>)

                (the .public <monoid>
                     (Monoid Revolution)
                     (implementation
                      (the identity <identity>)
                      (the composite <name>)))]

               [[or  /.major disjunction ..false]
                [and /.minor conjunction ..true]])

(the .public (not input)
     (-> Revolution Revolution)
     (/.- input ..true))

(the .public (implies consequent antecedent)
     (-> Revolution Revolution Revolution)
     (or (not antecedent)
         consequent))

(the .public (= left right)
     (-> Revolution Revolution Revolution)
     (and (or (not left) right)
          (or left (not right))))
