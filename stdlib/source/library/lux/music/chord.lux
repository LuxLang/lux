(.using
 [library
  [lux (.except Quality)
   [abstract
    [equality (.only Equality)]]
   [data
    ["[0]" pair]
    ["[0]" text (.only)
     ["%" \\injection]]
    [collection
     ["[0]" sequence (.only Sequence) (.open monoid)]
     ["[0]" list]]]
   [math
    [number
     [/64
      ["[0]" natural]]]]
   [macro
    ["[0]" template]]]]
 [//
  ["[0]" interval (.only Interval)]
  ["[0]" pitch (.only Pitch)]])

(comment "https://en.wikipedia.org/wiki/Chord_(music)"
         (every .public Chord
                (Sequence Interval)))

(the .public equality
     (Equality Chord)
     (sequence.equality natural.equality))

(alias [=]
       ..equality)

(the .public (as_text it)
     (text.Injection Chord)
     (sequence.mix (function (_ interval it)
                             (when it
                                   "" (%.natural interval)
                                   _ (text it " " (%.natural interval))))
                   it
                   ""))

(the .public size
     (-> Chord
         Natural)
     (|>> sequence.size
          ++))

(comment "https://en.wikipedia.org/wiki/Chord_notation"
         "https://en.wikipedia.org/wiki/Chord_notation#Triads"
         "https://en.wikipedia.org/wiki/Monad_(music)"
         (the .public monad
              Chord
              (sequence.new)))

(comment "https://en.wikipedia.org/wiki/Dyad_(music)"
         "https://en.wikipedia.org/wiki/Power_chord"
         (the .public power
              Chord
              (sequence.new interval.perfect_5th)))

(comment "https://en.wikipedia.org/wiki/Triad_(music)"
         "https://en.wikipedia.org/wiki/Major_chord"
         (the .public major_triad
              Chord
              (sequence.new interval.major_3rd
                            interval.minor_3rd)))

(comment "https://en.wikipedia.org/wiki/Minor_chord"
         (the .public minor_triad
              Chord
              (sequence.new interval.minor_3rd
                            interval.major_3rd)))

(comment "https://en.wikipedia.org/wiki/Augmented_triad"
         (the .public augmented_triad
              Chord
              (sequence.new interval.major_3rd
                            interval.major_3rd)))

(comment "https://en.wikipedia.org/wiki/Diminished_triad"
         (the .public diminished_triad
              Chord
              (sequence.new interval.minor_3rd
                            interval.minor_3rd)))

(comment "https://en.wikipedia.org/wiki/Suspended_chord"
         (the .public suspended_2
              Chord
              (sequence.new interval.major_2nd
                            interval.perfect_4th)))

(the .public suspended_4
     Chord
     (sequence.new interval.perfect_4th
                   interval.major_2nd))

(comment "https://en.wikipedia.org/wiki/Chord_notation#Chord_quality"
         (every .public Quality
                (Change Chord)))

(comment "https://en.wikipedia.org/wiki/Added_tone_chord"
         (the .public added
              (-> Interval
                  Quality)
              sequence.suffix))

(the .public major
     Quality
     (..added interval.major_3rd))

(the .public minor
     Quality
     (..added interval.minor_3rd))

(comment "https://en.wikipedia.org/wiki/Tetrad_(music)"
         (template.with [<base> <major> <minor>]
                        [(the .public <major>
                              Chord
                              (..major <base>))

                         (the .public <minor>
                              Chord
                              (..minor <base>))]

                        [[..major_triad major_7th dominant_7th]
                         [..minor_triad minor_major_7th minor_7th]
                         [..augmented_triad augmented_major_7th augmented_7th]

                         [..dominant_7th dominant_9th dominant_minor_9th]]))

(comment "https://en.wikipedia.org/wiki/Pentachord"
         (template.with [<base> <major> <minor>]
                        [(the .public <major>
                              Chord
                              (..major (..major <base>)))

                         (the .public <minor>
                              Chord
                              (..major (..minor <base>)))]

                        [[..minor_triad minor_major_9th minor_9th]
                         [..augmented_triad augmented_major_9th augmented_dominant_9th]]))

(comment "https://en.wikipedia.org/wiki/Polychord"
         (the .public (poly lower higher)
              (-> Chord Chord
                  Chord)
              (let [range (|> (sequence.mix natural.+ lower 0)
                              (natural.% interval.octave))
                    offset (natural.- range interval.octave)]
                   (sequence:composite (sequence.suffix offset lower)
                                       higher))))

(the .public (instance tonic it)
     (-> Pitch Chord
         (Sequence Pitch))
     (let [[pitch chord] (sequence.mix (function (_ interval [pitch chord])
                                                 [(natural.+ interval pitch)
                                                  (sequence.suffix pitch chord)])
                                       it
                                       [tonic (sequence.new)])]
          (sequence.suffix pitch chord)))

(the .public (chord it)
     (-> (Sequence Pitch)
         Chord)
     (pair.left (list.mix (function (_ pitch [chord first? offset])
                                    [(if first?
                                         chord
                                         (sequence.suffix (natural.- offset pitch) chord))
                                     false
                                     pitch])
                          (|> it
                              sequence.as_list
                              (list.in_order natural.<))
                          [(sequence.new) true 0])))

(<| (comment "https://en.wikipedia.org/wiki/Factor_(chord)")
    (every .public Factor)
    Natural)

(template.with [<it> <name> ,comment]
               [(the .public <name>
                     Factor
                     <it>)]

               [[00 root "https://en.wikipedia.org/wiki/Root_(chord)"]
                [02 third "https://en.wikipedia.org/wiki/Third_(chord)"]
                [04 fifth "https://en.wikipedia.org/wiki/Fifth_(chord)"]
                [05 sixth "https://en.wikipedia.org/wiki/Sixth_chord"]
                [06 seventh "https://en.wikipedia.org/wiki/Seventh_(chord)"]
                [08 ninth "https://en.wikipedia.org/wiki/Ninth"]
                [10 eleventh "https://en.wikipedia.org/wiki/Eleventh"]
                [12 thirteenth "https://en.wikipedia.org/wiki/Thirteenth"]])
