(.using
 [library
  [lux (.except natural)]]
 [//
  [pitch (.only Pitch)]])

(comment "https://en.wikipedia.org/wiki/Accidental_(music)"
         (every .public Accidental
                (Change Pitch)))

(comment "https://en.wikipedia.org/wiki/Sharp_(music)"
         (the .public sharp
              Accidental
              ++))

(the .public double_sharp
     Accidental
     (|>> ..sharp
          ..sharp))

(comment "https://en.wikipedia.org/wiki/Flat_(music)"
         (the .public flat
              Accidental
              --))

(the .public double_flat
     Accidental
     (|>> ..flat
          ..flat))

(comment "https://en.wikipedia.org/wiki/Natural_(music)"
         (the .public natural
              Accidental
              (|>>)))
