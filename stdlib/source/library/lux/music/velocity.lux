(.using
 [library
  [lux (.except)
   [math
    ["[0]" number]]
   [macro
    ["[0]" template]]]])

(comment "https://en.wikipedia.org/wiki/Dynamics_(music)"
         (every .public Velocity
                Natural))

(the .public mute
     Velocity
     (number.base_08 "000"))

(template.with [<code> <short> <long>]
               [(the .public <short>
                     Velocity
                     (number.base_08 <code>))

                (alias [<long>]
                       <short>)]

               [["020" ppp pianississimo]
                ["040" pp pianissimo]
                ["060" p piano]
                ["100" mp mezzo_piano]
                
                ["120" mf mezzo_forte]
                ["140" f forte]
                ["160" ff fortissimo]
                ["177" fff fortississimo]])
