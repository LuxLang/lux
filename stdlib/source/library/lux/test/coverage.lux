(.using
 [library
  [lux (.except name)
   [abstract
    ["[0]" monad]]
   [data
    ["[0]" text (.only)
     ["%" \\injection]]
    [collection
     ["[0]" list (.open functor)]
     ["[0]" set (.only Set)]]]
   [macro
    ["[0]" syntax]]
   ["[0]" meta (.only)
    ["[0]" binding]
    ["[0]" name]
    ["[0]" code (.only)
     ["<[1]>" \\projection]]]]])

(every .public Coverage
       (Set Name))

(the (name name)
     (-> Name
         Code)
     (` (is Name
            [(, (code.text (name.module name)))
             (, (code.text (name.proper name)))])))

(syntax.the .public (of [it <code>.global])
            (monad.let meta.monad
                       [_ (meta.or (binding.export it)
                                   (binding.default it))]
                       (pure (list (..name it)))))

(comment "https://en.wikipedia.org/wiki/Delimiter"
         (the delimiter
              Text
              (text.of_character 31)))

(the .public as_text
     (-> (List Text)
         Text)
     (text.interposed ..delimiter))

(the .public (of_text module encoding)
     (-> Text Text
         Coverage)
     (list.mix (function (_ proper it)
                         (set.has [module proper] it))
               (text.all_split_by ..delimiter encoding)
               (set.empty name.hash)))
