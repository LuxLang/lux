(.using
 [library
  [lux (.except Type Stack
                static)
   [abstract
    [equality (.only Equality)]]
   [data
    ["[0]" pair]
    [binary
     ["[0]" \\injection (.only Injection) (.open monoid)]]]
   [math
    ["[0]" random (.only Random)]
    [number
     [/64
      ["n" natural]]]]
   [macro
    ["[0]" template]]]]
 ["[0]" /
  ["[1][0]" stack (.only Stack)]
  ["[1][0]" registry (.only Registry)]
  [////
   [type (.only Type)
    [category (.only Method)]]]])

(every .public Limit
       (Record
        [:stack Stack
         :registry Registry]))

(the .public random
     (Random Limit)
     (all random.and
          /stack.random
          /registry.random
          ))

(template.with [<name> <registry>]
               [(the .public (<name> type)
                     (-> (Type Method)
                         Limit)
                     [:stack /stack.empty
                      :registry (<registry> type)])]

               [[static /registry.static]
                [virtual /registry.virtual]])

(the .public length
     (all n.+
          (comment "u2 max_stack;"
                   /stack.length)
          (comment "u2 max_locals;"
                   /registry.length)
          ))

(the .public equality
     (Equality Limit)
     (all pair.equality
          /stack.equality
          /registry.equality
          ))

(alias [=]
       ..equality)

(the .public (as_binary limit)
     (Injection Limit)
     (all \\injection:composite
          (/stack.as_binary (its :stack limit))
          (/registry.as_binary (its :registry limit))
          ))
