(.comment "https://docs.oracle.com/javase/specs/jvms/se7/html/jvms-4.html#jvms-4.7.12"
          (.using
           [library
            [lux (.except)
             [abstract
              [equality (.only Equality)]]
             [data
              ["[0]" pair]
              ["[0]" binary
               ["![1]" \\injection (.only Injection) (.open monoid)]]
              [collection
               ["[0]" sequence (.only Sequence)]]]
             [math
              [number
               ["[0]" /16
                ["[1]" natural]]
               [/64
                ["n" natural]]]]]]))

(every .public Entry
       (Record
        [:start_program_counter /16.Number
         :line_number /16.Number]))

(the entry_length
     Natural
     (all n.+
          (comment "u2 start_pc;"
                   /16.size)
          (comment "u2 line_number;"
                   /16.size)
          ))

(the entry_equality
     (Equality Entry)
     (all pair.equality
          /16.equality
          /16.equality
          ))

(the (entry_as_binary it)
     (Injection Entry)
     (all !binary:composite
          (/16.as_binary (its :start_program_counter it))
          (/16.as_binary (its :line_number it))
          ))

(every .public Line_Number_Table
       (Sequence Entry))

(the .public empty
     Line_Number_Table
     sequence.empty)

(the .public (length it)
     (-> Line_Number_Table
         Natural)
     (all n.+
          (comment "u2 line_number_table_length;"
                   /16.size)
          (comment "line_number_table[line_number_table_length];"
                   (n.x entry_length (sequence.size it)))
          ))

(the .public equality
     (Equality Line_Number_Table)
     (sequence.equality entry_equality))

(alias [=]
       ..equality)

(the .public as_binary
     (Injection Line_Number_Table)
     (!binary.sequence_16 entry_as_binary))
