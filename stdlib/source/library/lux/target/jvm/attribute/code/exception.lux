(.using
 [library
  [lux (.except)
   [abstract
    [equality (.only Equality)]]
   [data
    ["[0]" pair]
    [binary
     ["[0]" \\injection (.only Injection)]]]
   [math
    [number
     ["[0]" /16
      ["[1]" natural]]
     [/64
      ["n" natural]]]]]]
 ["[0]" //
  ["//[1]" ///
   ["[1][0]" index (.only Index)]
   [constant
    [class (.only Class)]]
   [bytecode
    ["[1][0]" address (.only Address)]]]])

(every .public Exception
       (Record
        [:start Address
         :end Address
         :handler Address
         :catch (Index Class)]))

(the .public equality
     (Equality Exception)
     (all pair.equality
          ////address.equality
          ////address.equality
          ////address.equality
          ////index.equality
          ))

(alias [=]
       ..equality)

(comment "https://docs.oracle.com/javase/specs/jvms/se8/html/jvms-4.html#jvms-4.7.3"
         (the .public length
              Natural
              (all n.+
                   (comment "u2 start_pc;"
                            ////address.length)
                   (comment "u2 end_pc;"
                            ////address.length)
                   (comment "u2 handler_pc;"
                            ////address.length)
                   (comment "u2 catch_type;"
                            ////index.length)
                   )))

(the .public as_binary
     (Injection Exception)
     (all \\injection.and
          ////address.as_binary
          ////address.as_binary
          ////address.as_binary
          ////index.as_binary
          ))
