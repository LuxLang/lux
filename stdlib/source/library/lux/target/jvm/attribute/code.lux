(.using
 [library
  [lux (.except Code)
   [abstract
    [equality (.only Equality)]]
   [data
    ["[0]" pair]
    ["[0]" binary (.only Binary)]
    ["[0]" binary
     ["[1]F" \\injection (.only Injection) (.open monoid)]]
    [collection
     ["[0]" sequence (.only Sequence) (.open functor)]]]
   [math
    [number
     ["[0]" /16
      ["[1]" natural]]
     ["[0]" /32
      ["[1]" natural]]
     [/64
      ["n" natural]]]]]]
 ["[0]" ///
  [bytecode
   [environment
    ["[1][0]" limit (.only Limit)]]]]
 ["[0]" /
  ["[1][0]" exception (.only Exception)]])

(every .public (Code Attribute)
       (Record
        [:limit Limit
         :code Binary
         :exception_table (Sequence Exception)
         :attributes (Sequence Attribute)]))

(the .public (length length code)
     (for_any (_ Attribute) (-> (-> Attribute Natural) (Code Attribute) Natural))
     (all n.+
          (comment "u2 max_stack;"
                   "u2 max_locals;"
                   ///limit.length)
          (comment "u4 code_length;"
                   /32.size)
          (comment "u1 code[code_length];"
                   (binary.size (its :code code)))
          (comment "u2 exception_table_length;"
                   /16.size)
          (comment "exception_table[exception_table_length];"
                   (|> code
                       (its :exception_table)
                       sequence.size
                       (n.x /exception.length)))
          (comment "u2 attributes_count;"
                   /16.size)
          (comment "attribute_info attributes[attributes_count];"
                   (sequence.mix n.+
                                 (|> code
                                     (its :attributes)
                                     (sequence:each length))
                                 0))))

(the .public (equality attribute_equality)
     (for_any (_ attribute)
              (-> (Equality attribute)
                  (Equality (Code attribute))))
     (all pair.equality
          ///limit.equality
          binary.equality
          (sequence.equality /exception.equality)
          (sequence.equality attribute_equality)
          ))

(comment "https://docs.oracle.com/javase/specs/jvms/se8/html/jvms-4.html#jvms-4.7.3"
         (the .public (as_binary as_binary code)
              (for_any (_ Attribute)
                       (-> (Injection Attribute)
                           (Injection (Code Attribute))))
              (all binaryF:composite
                   (comment "u2 max_stack;"
                            "u2 max_locals;"
                            (///limit.as_binary (its :limit code)))
                   (comment "u4 code_length;"
                            "u1 code[code_length];"
                            (binaryF.binary_32 (its :code code)))
                   (comment "u2 exception_table_length;"
                            "exception_table[exception_table_length];"
                            ((binaryF.sequence_16 /exception.as_binary) (its :exception_table code)))
                   (comment "u2 attributes_count;"
                            "attribute_info attributes[attributes_count];"
                            ((binaryF.sequence_16 as_binary) (its :attributes code)))
                   )))
