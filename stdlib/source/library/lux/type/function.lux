(.using
 [library
  [lux (.except special)
   ["[0]" error]
   [abstract
    ["?" projection]
    ["[0]" monad]]
   [data
    ["[0]" pair]
    [collection
     ["[0]" list (.only)
      ["?[1]" \\projection]]]]
   [macro
    ["[0]" syntax]]
   ["[0]" meta (.open functor)
    ["[0]" binding]
    ["[0]" code
     ["?[1]" \\projection]]]]]
 ["[0]" //])

(the (special it parameters)
     (-> Name (List Code)
         (Meta [(List Type) Type]))
     (monad.let [! meta.monad]
                [[it _] (binding.export it)
                 parameters (list.each' ! (|>> (meta.eval Type)
                                               (by ! each (|>> (.as (-> Any Type)))))
                                        parameters)
                 it (when (//.reified parameters it)
                          {.:Some it}
                          (pure it)

                          {.:None}
                          (meta.failure error.not_valid))]
                (pure (//.flat_function it))))

(the as_type
     (-> Type
         Code)
     (|>> //.code
          (,)
          (is Type)
          (`)))

(comment "https://en.wikipedia.org/wiki/Domain_of_a_function"
         (syntax.the .public (domain [function ?code.global
                                      arguments (?code.tuple (?.some ?list.any))])
                     (meta:each (|>> pair.left
                                     //.tuple
                                     ..as_type
                                     list)
                                (special function arguments))))

(comment "https://en.wikipedia.org/wiki/Image_(mathematics)"
         (syntax.the .public (image [function ?code.global
                                     arguments (?code.tuple (?.some ?list.any))])
                     (meta:each (|>> pair.right
                                     ..as_type
                                     list)
                                (special function arguments))))
