(.using
 [library
  [lux (.except Type text)
   [data
    ["[0]" text]]
   [macro
    ["[0]" template]]]])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#input_types")
    (every .public Type)
    Text)

(template.with [<name>]
               [(the .public <name>
                     Type
                     (|> (template.text [<name>])
                         (text.replaced "local_date_time" "datetime-local")
                         (text.replaced "telephone" "tel")
                         (text.replaced "_" "")))]

               [[button]
                [check_box]
                [color]
                [date]
                [local_date_time]
                [email]
                [file]
                [hidden]
                [image]
                [month]
                [number]
                [password]
                [radio]
                [range]
                [reset]
                [search]
                [submit]
                [telephone]
                [text]
                [time]
                [url]
                [week]
                ])
