(.using
 [library
  [lux (.except Type)
   [macro
    ["[0]" template]]]])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/button#attributes")
    (every .public Type)
    Text)

(template.with [<name>]
               [(the .public <name>
                     Type
                     (template.text [<name>]))]

               [[submit]
                [reset]
                [button]
                ])
