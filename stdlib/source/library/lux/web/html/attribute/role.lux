(.using
 [library
  [lux (.except list)
   [data
    ["[0]" text]]
   [macro
    ["[0]" template]]]])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/Accessibility/ARIA/Roles")
    (every .public Role)
    Text)

(`` (`` (template.with [<name>]
                       [(the .public <name>
                             Role
                             (|> (template.text [<name>])
                                 (text.replaced "_" "")
                                 (text.replaced "image" "img")))]

                       [(,, (comment "https://developer.mozilla.org/en-US/docs/Web/Accessibility/ARIA/Roles#1._document_structure_roles"
                                     (,, (these [toolbar]
                                                [tooltip]
                                                [feed]
                                                [math]
                                                [presentation]
                                                [note]))))

                        [application]
                        [article]
                        [cell]
                        [column_header]
                        [definition]
                        [directory]
                        [document]
                        [figure]
                        [group]
                        [heading]
                        [image]
                        [list]
                        [list_item]
                        [meter]
                        [row]
                        [row_group]
                        [row_header]
                        [table]
                        [term]

                        [association_list]
                        [association_list_item_key]
                        [association_list_item_value]
                        [block_quote]
                        [caption]
                        [code]
                        [deletion]
                        [emphasis]
                        [insertion]
                        [paragraph]
                        [strong]
                        [sub_script]
                        [super_script]
                        [time]

                        (,, (comment "https://developer.mozilla.org/en-US/docs/Web/Accessibility/ARIA/Roles#2._widget_roles"
                                     (,, (these [scroll_bar]
                                                [search_box]
                                                [separator]
                                                [slider]
                                                [spin_button]
                                                [switch]
                                                [tab]
                                                [tab_panel]
                                                [tree_item]))))

                        [combo_box]
                        [menu]
                        [menu_bar]
                        [tab_list]
                        [tree]
                        [tree_grid]

                        [button]
                        [check_box]
                        [grid_cell]
                        [link]
                        [menu_item]
                        [menu_item_check_box]
                        [menu_item_radio]
                        [option]
                        [progress_bar]
                        [radio]
                        [text_box]

                        (,, (comment "https://developer.mozilla.org/en-US/docs/Web/Accessibility/ARIA/Roles#3._landmark_roles"
                                     (,, (these [banner]
                                                [complementary]
                                                [content_info]
                                                [form]
                                                [main]
                                                [navigation]
                                                [region]
                                                [search]))))

                        (,, (comment "https://developer.mozilla.org/en-US/docs/Web/Accessibility/ARIA/Roles#4._live_region_roles"
                                     (,, (these [alert]
                                                [log]
                                                [marquee]
                                                [status]
                                                [timer]))))

                        (,, (comment "https://developer.mozilla.org/en-US/docs/Web/Accessibility/ARIA/Roles#5._window_roles"
                                     (,, (these [alert_dialog]
                                                [dialog]))))

                        (,, (comment "https://developer.mozilla.org/en-US/docs/Web/Accessibility/ARIA/Roles#6._abstract_roles"
                                     (,, (these [command]
                                                [composite]
                                                [input]
                                                [landmark]
                                                [range]
                                                [role_type]
                                                [section]
                                                [section_head]
                                                [select]
                                                [structure]
                                                [widget]
                                                [window]))))
                        ])))
