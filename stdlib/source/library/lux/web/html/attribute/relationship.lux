(.using
 [library
  [lux (.except)
   [data
    ["[0]" text]]
   [macro
    ["[0]" template]]]])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/rel")
    (every .public Relationship)
    Text)

(template.with [<name>]
               [(the .public <name>
                     Relationship
                     (|> (template.text [<name>])
                         (text.replaced "no_" "no")
                         (text.replaced "pre_" "pre")
                         (text.replaced "module_" "module")
                         (text.replaced "_" "-")))]

               [[alternate]
                [author]
                [bookmark]
                [canonical]
                [dns_prefetch]
                [external]
                [help]
                [icon]
                [license]
                [manifest]
                [me]
                [module_pre_load]
                [next]
                [no_follow]
                [no_opener]
                [no_referrer]
                [opener]
                [pingback]
                [pre_connect]
                [pre_fetch]
                [pre_load]
                [pre_render]
                [prev]
                [search]
                [stylesheet]
                [tag]
                ])
