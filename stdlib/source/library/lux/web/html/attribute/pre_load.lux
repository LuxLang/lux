(.using
 [library
  [lux (.except)
   [data
    ["[0]" text]]
   [macro
    ["[0]" template]]]])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/audio#attributes"
             "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/video#attributes")
    (every .public Pre_Load)
    Text)

(template.with [<name>]
               [(the .public <name>
                     Pre_Load
                     (|> (template.text [<name>])
                         (text.replaced "matic" "")
                         (text.replaced "_" "")))]

               [[none]
                [meta_data]
                [automatic]
                ])
