(.using
 [library
  [lux (.except Source)
   [data
    ["[0]" text (.only)
     ["%" \\injection]]]
   [macro
    ["[0]" expansion]
    ["[0]" template]]
   [type
    ["[0]" nominal]]
   [world
    [net (.only URL)]]]])

(<| (comment "https://developer.mozilla.org/en-US/docs/Learn/HTML/Multimedia_and_embedding/Responsive_images")
    (nominal.every .public Source
                   Text

                   (template.with [<suffix> <name> <type> <injection>]
                                  [(the .public (<name> parameter url)
                                        (-> <type> URL
                                            Source)
                                        (nominal.of
                                         (text url " " (<injection> parameter) <suffix>)))]

                                  [["w" by_width Natural %.natural]
                                   ["x" by_density Real %.real]])

                   (the .public source
                        (-> Source
                            Text)
                        (|>> nominal.as))
                   ))
