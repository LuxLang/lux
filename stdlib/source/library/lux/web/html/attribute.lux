(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/img#attributes"
             "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/source#attributes")
    (the .public sizes
         (Name [(Value Length) (List [query.Feature (Value Length)])]))
    [:label "sizes"
     :as (function (_ [default conditionals])
                   {.:Some (.text (|> conditionals
                                      (list:each (function (_ [feature length])
                                                           (.text (query.feature feature)
                                                                  " " (value.value length)
                                                                  ", ")))
                                      (text.interposed ""))
                                  (value.value default))})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/img#attributes"
             "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/source#attributes")
    (the .public source_set
         (Name (List Source)))
    [:label "srcset"
     :as (function (_ it)
                   (when it
                         (.list)
                         {.:None}

                         _
                         {.:Some (|> it
                                     (list:each source.source)
                                     (text.interposed ", "))}))])

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name Integer))
                    [:label (|> (template.text [<name>])
                                (text.replaced "_" ""))
                     :as (|>> %.integer
                              {.:Some})])]

               [[start "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/ol#start"]
