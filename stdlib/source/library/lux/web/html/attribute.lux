(.using
 [library
  [lux (.except Scope Source
                text loop pattern type list open
                Name name)
   [data
    ["[0]" text (.only)
     [character (.only Character)]
     ["%" \\injection]]
    [collection
     ["[0]" list (.open functor)]]]
   [macro
    ["[0]" template]]
   [type
    ["[0]" nominal]]
   [time
    ["[0]" instant (.only Instant)]]
   [world
    [net (.only URL)
     ["[0]" mime (.only MIME)]]
    [locale
     ["[0]" language (.only Language)]]]]]
 [/
  [capitalization (.only Capitalization)]
  [completion (.only Completion)]
  [decoding (.only Decoding)]
  [text_direction (.only Text_Direction)]
  [drag (.only Drag)]
  [enter (.only Enter)]
  [input_mode (.only Input_Mode)]
  [pre_load (.only Pre_Load)]
  [referrer_policy (.only Referrer_Policy)]
  [relationship (.only Relationship)]
  [role (.only Role)]
  [sandbox (.only Sandbox)]
  [shape (.only Shape)]
  [target (.only Target)]
  [pragma (.only Pragma)]
  ["[0]" source (.only Source)]
  [type
   ["[0]" button]
   ["[0]" input]
   ["[0]" numbering]
   ["[0]" script]]
  [///
   ["[0]" permission]
   [css
    ["[0]" id (.only ID)]
    ["[0]" class (.only Class)]
    ["[0]" query (.only Query)]
    ["[0]" value (.only Value Length)]
    ["[0]" style (.only Style)]]]])

(<| (comment "Properly formats text to ensure no injection can happen on the HTML.")
    (the safe
         (Change Text))
    (|>> (text.replaced "&" "&amp;")
         (text.replaced "<" "&lt;")
         (text.replaced ">" "&gt;")
         (text.replaced text.double_quote "&quot;")
         (text.replaced "'" "&#x27;")
         (text.replaced "/" "&#x2F;")))

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes#attribute_list")
    (every .public (Injection it))
    (-> it
        (Maybe Text)))

(every .public (Name it)
       (Record
        [:label Text
         :as (Injection it)]))

(every .public (Attribute it)
       (Record
        [:name (Name it)
         :value it]))

(every .public Attributes
       (List (for_some (_ it)
                       (Attribute it))))

(the .public empty
     Attributes
     (.list))

(template.with [<name>]
               [(the .public <name>
                     MIME
                     (mime.mime (template.text [<name> "/*"])))]

               [[audio]
                [application]
                [video]
                [image]
                [text]
                [font]])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/accept")
    (the .public accept
         (Name (List MIME)))
    [:label "accept"
     :as (|>> (list:each mime.name)
              (text.interposed ", ")
              ..safe
              {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/accesskey")
    (the .public access_key
         (Name Character))
    [:label "accesskey"
     :as (|>> text.of_character
              ..safe
              {.:Some})])

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name URL))
                    [:label (|> (template.text [<name>])
                                (text.replaced "form_" "form")
                                (text.replaced "source" "src"))
                     :as (|>> {.:Some})])]

               [[action ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/form#action"]]
                [cite ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/blockquote"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/ins"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/q"]]
                [data ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/object#data"]]
                [form_action ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"
                              "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/button#attributes"]]
                [href ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/a#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/area#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/base#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/link#attributes"]]
                [poster ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/video#poster"]]
                [source ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/audio#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/embed#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/iframe#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/img#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/script#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/source#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/track#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/video#attributes"]]
                ])

(alias [hyper_link]
       ..href)

(the Allowances
     (.type (Maybe (List permission.Allowance))))

(the Permission
     (.type [permission.Directive Allowances]))

(the (allowances it)
     (-> Allowances
         Text)
     (when it
           {.:None}
           "*"
           
           {.:Some it}
           (when it
                 (.list)
                 "'none'"

                 _
                 (text.interposed " " it))))

(the (permission [directive allowances])
     (-> Permission
         Text)
     (.text directive " " (..allowances allowances)))

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/iframe#allow")
    (the .public allow
         (Name (List Permission)))
    [:label "allow"
     :as (comment "https://developer.mozilla.org/en-US/docs/Web/HTTP/Permissions_Policy"
                  (|>> (list:each permission)
                       (text.interposed "; ")
                       ..safe
                       {.:Some}))])

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name Text))
                    [:label (|> (template.text [<name>])
                                (text.replaced "direction_" "dir")
                                (text.replaced "_property" "prop"))
                     :as (|>> ..safe
                              {.:Some})])]

               [[alt ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#alt"]]
                [content ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/meta#content"]]
                [direction_name ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"]]
                [item_property ["https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/itemprop"]]
                [label ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/optgroup#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/option#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/track#attributes"]]
                [name ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/button#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/form#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/fieldset#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/iframe#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/object#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/output#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/select#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/textarea#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/map#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/meta#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/param#attributes"]]
                [placeholder ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"
                              "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/textarea#attributes"]]
                [title "https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/title"]
                [value ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/button#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/data#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/li#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/meter#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/option#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/progress#attributes"]]
                ])

(the presential_bit
     (Injection Bit)
     (function (_ it)
               (if it
                   {.:Some ""}
                   {.:None})))

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name Bit))
                    [:label (|> (template.text [<name>])
                                (text.replaced "_" ""))
                     :as ..presential_bit])]

               [[async ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/script#async"]]
                [auto_play ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/audio"
                            "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/video"]]
                [checked ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#checked"]]
                [controls ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/audio#attributes"
                           "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/video#attributes"]]
                [default ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/track#default"]]
                [defer ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/script#defer"]]
                [disabled ["https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/disabled"]]
                [download ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/a#attributes"
                           "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/area#attributes"]]
                [form_no_validate ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/button#attributes"
                                   "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"]]
                [is_map ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/img#ismap"]]
                [loop ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/audio#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/video#attributes"]]
                [multiple ["https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/multiple"]]
                [muted ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/audio#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/video#attributes"]]
                [no_validate ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/form#novalidate"]]
                [open ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/details#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/dialog#attributes"]]
                [plays_inline ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/video#playsinline"]]
                [read_only ["https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/readonly"]]
                [required ["https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/required"]]
                [reversed ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/ol#reversed"]]
                [selected ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/option#selected"]]
                ])

(the verbose_bit
     (Injection Bit)
     (function (_ it)
               {.:Some (if it
                           "true"
                           "false")}))

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name Bit))
                    [:label (|> (template.text [<name>])
                                (text.replaced "_" ""))
                     :as ..verbose_bit])]

               [[spell_check ["https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/spellcheck"]]])

(the succinct_bit
     (Injection Bit)
     (function (_ it)
               {.:Some (if it
                           "yes"
                           "no")}))

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name Bit))
                    [:label (|> (template.text [<name>])
                                (text.replaced "_" ""))
                     :as ..succinct_bit])]

               [[translate ["https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/translate"]]])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/autocapitalize")
    (the .public auto_capitalize
         (Name Capitalization))
    [:label "autocapitalize"
     :as (|>> ..safe
              {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/autocomplete")
    (the .public auto_complete
         (Name Completion))
    [:label "autocomplete"
     :as (|>> ..safe
              {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/capture")
    (every .public Capture)
    Text)

(template.with [<name>]
               [(the .public <name>
                     Capture
                     (template.text [<name>]))]

               [[user]
                [environment]
                ])

(the .public capture
     (Name Capture)
     [:label "capture"
      :as (|>> ..safe
               {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/class")
    (the .public class
         (Name (List Class)))
    [:label "class"
     :as (|>> (list:each class.class)
              (text.interposed " ")
              ..safe
              {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/td#attributes"
             "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/th#attributes")
    (the .public minimum_column_span
         Natural)
    1)

(the .public maximum_column_span
     Natural
     1,000)

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name Natural))
                    [:label (|> (template.text [<name>])
                                (text.replaced "umn" "")
                                (text.replaced "_" ""))
                     :as (|>> %.natural
                              {.:Some})])]

               [[columns ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/textarea#cols"]]
                [column_span ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/td#attributes"
                              "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/th#attributes"]]
                [max_length ["https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/maxlength"]]
                [min_length ["https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/minlength"]]
                [rows ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/textarea#rows"]]
                [row_span ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/td#attributes"
                           "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/th#attributes"]]
                [size ["https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/size"]]
                [span ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/col#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/colgroup#attributes"]]
                [step ["https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/step"]]
                [height ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/canvas#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/embed#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/iframe#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/img#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/object#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/video#attributes"]]
                [width ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/canvas#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/embed#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/iframe#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/img#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/object#attributes"
                        "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/video#attributes"]]
                ])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/contenteditable")
    (every .public Editable)
    Text)

(template.with [<name> <value>]
               [(the .public <name>
                     Editable
                     <value>)]

               [[is_editable "true"]
                [not_editable "false"]
                [only_plain_text "plaintext-only"]
                ])

(the .public content_editable
     (Name Editable)
     [:label "contenteditable"
      :as (|>> ..safe
               {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/area#coords")
    (the .public coordinates
         (Name (List Natural)))
    [:label "coords"
     :as (|>> (list:each %.natural)
              (text.interposed ",")
              {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/crossorigin")
    (every .public Cross_Origin)
    Text)

(template.with [<name>]
               [(the .public <name>
                     Cross_Origin
                     (|> (template.text [<name>])
                         (text.replaced "_" "-")))]

               [[anonymous]
                [use_credentials]
                ])

(the .public cross_origin
     (Name Cross_Origin)
     [:label "crossorigin"
      :as (|>> ..safe
               {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/del#attributes"
             "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/ins#attributes"
             "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/time#attributes")
    (the .public date_time
         (Name Instant))
    [:label "datetime"
     :as (|>> instant.as_text
              {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/img#decoding")
    (the .public decoding
         (Name Decoding))
    [:label "decoding"
     :as (|>> ..safe
              {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/dir")
    (the .public text_direction
         (Name Text_Direction))
    [:label "dir"
     :as (|>> ..safe
              {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/draggable")
    (the .public draggable
         (Name Drag))
    [:label "draggable"
     :as (|>> ..safe
              {.:Some})])

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name MIME))
                    [:label (|> (template.text [<name>])
                                (text.replaced "encoding" "enc")
                                (text.replaced "_" ""))
                     :as (|>> mime.name
                              {.:Some})])]

               [[encoding_type ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/form#enctype"]]
                [form_encoding_type ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/button#attributes"
                                     "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"]]
                [type ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/embed#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/object#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/source#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/link#attributes"]]
                ])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/enterkeyhint")
    (the .public enter_key_hint
         (Name Enter))
    [:label "enterkeyhint"
     :as (|>> ..safe
              {.:Some})])

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name ID))
                    [:label (template.text [<name>])
                     :as (|>> id.id
                              ..safe
                              {.:Some})])]

               [[for ["https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/for"]]
                [form ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/button#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/fieldset#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/object#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/output#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/select#attributes"
                       "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/textarea#attributes"]]
                [id ["https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/id"]]
                [list ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#list"]]
                ])

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name Target))
                    [:label (|> (template.text [<name>])
                                (text.replaced "_" ""))
                     :as (|>> ..safe
                              {.:Some})])]

               [[form_target ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/button#attributes"
                              "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/input#attributes"]]
                [target ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/a#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/area#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/base#attributes"
                         "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/form#attributes"]]
                ])

(every .public Hidden
       Text)

(template.with [<name>]
               [(the .public <name>
                     Hidden
                     (|> (template.text [<name>])
                         (text.replaced "_" "-")
                         (text.replaced "forever" "hidden")))]

               [[forever]
                [until_found]])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/hidden")
    (the .public hidden
         (Name Hidden))
    [:label "hidden"
     :as (|>> ..safe
              {.:Some})])

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name Real))
                    [:label (template.text [<name>])
                     :as (|>> %.real
                              {.:Some})])]

               [[high "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/meter#high"]
                [low "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/meter#low"]
                [max "https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/max"]
                [min "https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/min"]
                [optimum "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/meter#optimum"]
                ])

(template.with [<name> ,comment]
               [(<| (comment ,comment)
                    (the .public <name>
                         (Name Language))
                    [:label (|> (template.text [<name>])
                                (text.replaced "language" "lang")
                                (text.replaced "source" "src")
                                (text.replaced "_" "-"))
                     :as (|>> language.name
                              {.:Some})])]

               [[href_language ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/a#attributes"
                                "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/link#attributes"]]
                [language ["https://developer.mozilla.org/en-US/docs/Web/HTML/Global_attributes/lang"]]
                [source_language ["https://developer.mozilla.org/en-US/docs/Web/HTML/Element/track#srclang"]]
                ])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/meta#http-equiv")
    (the .public http_equivalent
         (Name Pragma))
    [:label "http-equiv"
     :as (|>> ..safe
              {.:Some})])

(<| (comment "https://developer.mozilla.org/en-US/docs/Web/Security/Subresource_Integrity")
    (nominal.every Hash
                   Text

                   (template.with [<name>]
                                  [(the .public <name>
                                        (-> Text
                                            Hash)
                                        (let [prefix (|> (template.text [<name>])
                                                         (text.replaced "_" "-"))]
                                             (|>> (.text prefix "-")
                                                  nominal.of)))]
                                  
                                  [[sha_256]
                                   [sha_384]
                                   [sha_512]])

                   (the .public integrity
                        (Name Hash)
                        [:label "integrity"
                         :as (|>> nominal.as
                                  {.:Some})])
                   ))

