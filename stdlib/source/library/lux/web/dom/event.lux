                                            [selection_change "https://developer.mozilla.org/en-US/docs/Web/API/Document/selectionchange_event"]
                                            [visibility_change "https://developer.mozilla.org/en-US/docs/Web/API/Document/visibilitychange_event"]))))

                    (,, (comment "https://developer.mozilla.org/en-US/docs/Web/API/Element"
                                 (,, (these [animation_cancel "https://developer.mozilla.org/en-US/docs/Web/API/Element/animationcancel_event"]
                                            [animation_end "https://developer.mozilla.org/en-US/docs/Web/API/Element/animationend_event"]
