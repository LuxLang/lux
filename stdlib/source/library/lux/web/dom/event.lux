                                            [reset "https://developer.mozilla.org/en-US/docs/Web/API/HTMLFormElement/reset_event"]
                                            [submit "https://developer.mozilla.org/en-US/docs/Web/API/HTMLFormElement/submit_event"]))))

                    (,, (comment "https://developer.mozilla.org/en-US/docs/Web/API/HTMLInputElement"
                                 (,, (these [invalid "https://developer.mozilla.org/en-US/docs/Web/API/HTMLInputElement/invalid_event"]
                                            [select "https://developer.mozilla.org/en-US/docs/Web/API/HTMLInputElement/select_event"]))))

                    (,, (comment "https://developer.mozilla.org/en-US/docs/Web/API/HTMLMediaElement"
                                 (,, (these [can_play_through "https://developer.mozilla.org/en-US/docs/Web/API/HTMLMediaElement/canplaythrough_event"]
                                            [can_play "https://developer.mozilla.org/en-US/docs/Web/API/HTMLMediaElement/canplay_event"]
                                            [duration_change "https://developer.mozilla.org/en-US/docs/Web/API/HTMLMediaElement/durationchange_event"]
                                            [emptied "https://developer.mozilla.org/en-US/docs/Web/API/HTMLMediaElement/emptied_event"]
                                            [ended "https://developer.mozilla.org/en-US/docs/Web/API/HTMLMediaElement/ended_event"]
                                            [loaded_data "https://developer.mozilla.org/en-US/docs/Web/API/HTMLMediaElement/loadeddata_event"]
                                            [loaded_meta_data "https://developer.mozilla.org/en-US/docs/Web/API/HTMLMediaElement/loadedmetadata_event"]
