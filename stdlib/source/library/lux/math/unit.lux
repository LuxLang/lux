(.using
 [library
  [lux (.except)]])

(comment "https://en.wikipedia.org/wiki/Unit_of_measurement"
         (every .public (Unit it)
                (Record [:factor it
                         :suffix Text])))

(the with_template (.in_module# .prelude .with_template))

(`` (with_template [,it ,factor ,suffix ,name]
                   [(the .public ,name
                         (Unit ,it)
                         [:factor ,factor
                          :suffix ,suffix])]

                   [(,, (comment "https://en.wikipedia.org/wiki/Degree_(angle)"
                                 [Natural 360 "°" degree]))

                    (,, (comment "https://en.wikipedia.org/wiki/Gradian"
                                 [Natural 400 "g" gradian]))

                    (,, (comment "https://en.wikipedia.org/wiki/Percentage"
                                 [Natural 00,100 "%" per_cent]))

                    (,, (comment "https://en.wikipedia.org/wiki/Per_mille"
                                 [Natural 01,000 "‰" per_mille]))

                    (,, (comment "https://en.wikipedia.org/wiki/Basis_point"
                                 [Natural 10,000 "‱" per_myriad]))

                    (,, (comment "https://en.wikipedia.org/wiki/Pi"
                                 "https://en.wikipedia.org/wiki/Radian"
                                 [Real +3.14159265358979323846 "π" radian]))

                    (,, (comment "https://en.wikipedia.org/wiki/Tau"
                                 "https://en.wikipedia.org/wiki/Turn_(angle)"
                                 [Real +6.28318530717958647692 "τ" turn]))]
                   ))
