(.using
 [library
  [lux (.except)
   [logic
    ["[0]" bit]]]])

(the with_template (.in_module# .prelude .with_template))

(<| (comment "https://en.wikipedia.org/wiki/Sign_function")
    (every .public Signum)
    Bit)

(the .public x
     (-> Signum
         (Change Signum))
     bit.or)

(with_template [,name ,value]
               [(the .public ,name
                     Signum
                     ,value)]

               [[positive 0b]
                [negative 1b]
                ])

(the .public (as_text it)
     (-> Signum
         Text)
     (when it
           ..positive "+"
           ..negative "-"))
