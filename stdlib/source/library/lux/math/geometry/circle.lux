(.using
 [library
  [lux (.except)
   [math
    [number
     [/64
      ["r" real]]]]
   [macro
    ["[0]" template]]
   ["[0]" target]]]
 [///
  ["[0]" unit]])

(every .public Angle
       Real)

(`` (template.with [,name ,unit]
                   [(the .public ,name
                         Angle
                         (its unit.:factor ,unit))]

                   [(,, (comment "['π is wrong!' by Bob Palais](https://www.math.utah.edu/~palais/pi.html)"
                                 [pi  unit.radian]))
                    (,, (comment "[The Tau Manifesto](https://tauday.com/tau-manifesto)"
                                 [tau unit.turn]))]))

(comment "https://en.wikipedia.org/wiki/Turn_(angle)"
         (the .public turn
              Angle
              ..tau))

(comment "https://en.wikipedia.org/wiki/Radian"
         (the .public radian
              Angle
              +1.0))

(comment "https://en.wikipedia.org/wiki/Degree_(angle)"
         (the .public degree
              Angle
              (r.of_degree ..tau)))

(comment "https://en.wikipedia.org/wiki/Gradian"
         (the .public gradian
              Angle
              (r.of_gradian ..tau)))

(comment "https://en.wikipedia.org/wiki/Trigonometric_functions"
         "https://en.wikipedia.org/wiki/Inverse_trigonometric_functions"
         (target.if target.jvm
                    (these (the !double
                                (template.macro (_ value)
                                                [(|> value
                                                     (as (-> Real (Nominal "java.lang.Double")))
                                                     .jvm_object_cast#)]))
                           
                           (the !real
                                (template.macro (_ value)
                                                [(|> value
                                                     .jvm_object_cast#
                                                     (as (-> (Nominal "java.lang.Double") Real)))]))
                           
                           (template.with [<input> <output> <name> <method>]
                                          [(the .public <name>
                                                (-> <input>
                                                    <output>)
                                                (|>> !double
                                                     ["D"]
                                                     (.jvm_member_invoke_static# [] "java.lang.Math" <method> [])
                                                     !real))]

                                          [[Angle Real cos "cos"]
                                           [Angle Real sin "sin"]
                                           [Angle Real tan "tan"]

                                           [Real Angle acos "acos"]
                                           [Real Angle asin "asin"]
                                           [Real Angle atan "atan"]]))

                    target.js
                    (these (template.with [<input> <output> <name> <method>]
                                          [(the .public <name>
                                                (-> <input>
                                                    <output>)
                                                (|>> []
                                                     (.js_of# (.js_constant# <method>))
                                                     (as (-> Any Real))))]

                                          [[Angle Real cos "Math.cos"]
                                           [Angle Real sin "Math.sin"]
                                           [Angle Real tan "Math.tan"]

                                           [Real Angle acos "Math.acos"]
                                           [Real Angle asin "Math.asin"]
                                           [Real Angle atan "Math.atan"]]))

                    target.python
                    (these (template.with [<input> <output> <name> <method>]
                                          [(the .public <name>
                                                (-> <input>
                                                    <output>)
                                                (|>> []
                                                     (.python_object_do# <method> (.python_import# "math"))
                                                     (as (-> Any Real))))]

                                          [[Angle Real cos "cos"]
                                           [Angle Real sin "sin"]
                                           [Angle Real tan "tan"]

                                           [Real Angle acos "acos"]
                                           [Real Angle asin "asin"]
                                           [Real Angle atan "atan"]]))

                    target.lua
                    (these (template.with [<input> <output> <name> <method>]
                                          [(the .public <name>
                                                (-> <input>
                                                    <output>)
                                                (|>> []
                                                     (.lua_of# (.lua_constant# <method>))
                                                     (as (-> Any Real))))]

                                          [[Angle Real cos "math.cos"]
                                           [Angle Real sin "math.sin"]
                                           [Angle Real tan "math.tan"]

                                           [Real Angle acos "math.acos"]
                                           [Real Angle asin "math.asin"]
                                           [Real Angle atan "math.atan"]]))

                    target.ruby
                    (these (template.with [<input> <output> <name> <method>]
                                          [(the .public <name>
                                                (-> <input>
                                                    <output>)
                                                (|>> []
                                                     (.ruby_of# (.ruby_constant# <method>))
                                                     (as (-> Any Real))))]

                                          [[Angle Real cos "Math.cos"]
                                           [Angle Real sin "Math.sin"]
                                           [Angle Real tan "Math.tan"]

                                           [Real Angle acos "Math.acos"]
                                           [Real Angle asin "Math.asin"]
                                           [Real Angle atan "Math.atan"]]))

                    target.php
                    (these (template.with [<input> <output> <name> <method>]
                                          [(the .public <name>
                                                (-> <input>
                                                    <output>)
                                                (|>> ("php of" ("php constant" <method>))
                                                     (as (-> Any Real))))]

                                          [[Angle Real cos "cos"]
                                           [Angle Real sin "sin"]
                                           [Angle Real tan "tan"]

                                           [Real Angle acos "acos"]
                                           [Real Angle asin "asin"]
                                           [Real Angle atan "atan"]]))
                    ))

(the .public (atan_2 x y)
     (-> Real Real
         Real)
     (if (r.< x +0.0)
         (..atan (r./ x y))

         (r.< +0.0 x)
         (if (and/or (r.< y +0.0)
                     (r.= +0.0 y))
             (|> y (r./ x) atan (r.+ pi))
             (|> y (r./ x) atan (r.- pi)))

         (comment (r.= +0.0 x)
                  (if (r.< y +0.0)
                      (|> pi (r./ +2.0))
                      
                      (r.< +0.0 y)
                      (|> pi (r./ -2.0))
                      
                      (comment (r.= +0.0 y)
                               (r./ +0.0 +0.0))))))

(the .public (hypotenuse catA catB)
     (-> Real Real
         Real)
     (r.^ +0.5 (r.+ (r.x catA catA)
                    (r.x catB catB))))

(alias [sine]
       ..sin)

(alias [co_sine]
       ..cos)

(alias [tangent]
       ..tan)

(template.with [<name> <reciprocal>]
               [(the .public <name>
                     (-> Angle
                         Real)
                     (|>> <reciprocal>
                          r.reciprocal))]

               [[secant co_sine]
                [co_secant sine]
                [co_tangent tangent]])

(alias [sec]
       ..secant)

(alias [csc]
       ..co_secant)

(alias [cot]
       ..co_tangent)

(template.with [<name> <reciprocal>]
               [(the .public <name>
                     (-> Angle
                         Real)
                     (|>> r.reciprocal
                          <reciprocal>))]

               [[arc_secant ..acos]
                [arc_co_secant ..asin]
                [arc_co_tangent ..atan]])

(alias [arc_sine]
       ..asin)

(alias [arc_co_sine]
       ..acos)

(alias [arc_tangent]
       ..atan)

(alias [arc_tangent_2]
       ..atan_2)

(alias [asec]
       ..arc_secant)

(alias [acsc]
       ..arc_co_secant)

(alias [acot]
       ..arc_co_tangent)
